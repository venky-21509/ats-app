<%= form_with model: [@job, @application], style: "max-width: 600px;" do |f| %>
  <% if @application.errors.any? %>
    <div style="background: #f8d7da; color: #721c24; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem;">
      <% @application.errors.full_messages.each do |msg| %>
        <p style="margin: 0;"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div style="margin-bottom: 1rem;">
    <%= f.label :cover_letter, style: "display: block; font-weight: bold; margin-bottom: 0.25rem;" %>
    <%= f.text_area :cover_letter, rows: 8, placeholder: "Tell us why you're a great fit...",
        style: "width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;" %>
  </div>

  <div style="margin-bottom: 1.5rem;">
    <%= f.label :resume, "Resume (PDF or Word)", style: "display: block; font-weight: bold; margin-bottom: 0.25rem;" %>
    <%= f.file_field :resume, style: "width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;" %>
  </div>

  <%= f.submit "Submit Application",
      style: "background: #27ae60; color: white; padding: 0.6rem 1.5rem; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem;" %>
  <%= link_to "Cancel", job_path(@job), style: "margin-left: 1rem; color: #666;" %>
<% end %>