<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
  <h1>Applications for <%= @job&.title %></h1>
</div>

<div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
  <%= link_to "All", job_applications_path(@job),
      style: "padding: 0.3rem 0.75rem; border-radius: 20px; background: #{params[:status].blank? ? '#2c3e50' : '#eee'}; color: #{params[:status].blank? ? 'white' : '#333'}; text-decoration: none; font-size: 0.85rem;" %>
  <% Application.statuses.each_key do |s| %>
    <%= link_to s.humanize, job_applications_path(@job, status: s),
        style: "padding: 0.3rem 0.75rem; border-radius: 20px; background: #{params[:status] == s ? '#2c3e50' : '#eee'}; color: #{params[:status] == s ? 'white' : '#333'}; text-decoration: none; font-size: 0.85rem;" %>
  <% end %>
</div>

<% if @applications.any? %>
  <table style="width: 100%; border-collapse: collapse;">
    <thead>
      <tr style="background: #f8f9fa;">
        <th style="padding: 0.75rem; text-align: left; border-bottom: 2px solid #ddd;">Candidate</th>
        <th style="padding: 0.75rem; text-align: left; border-bottom: 2px solid #ddd;">Applied</th>
        <th style="padding: 0.75rem; text-align: left; border-bottom: 2px solid #ddd;">Status</th>
        <th style="padding: 0.75rem; text-align: left; border-bottom: 2px solid #ddd;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @applications.each do |app| %>
        <tr style="border-bottom: 1px solid #eee;">
          <td style="padding: 0.75rem;"><%= app.user.full_name %></td>
          <td style="padding: 0.75rem; color: #666;"><%= app.applied_at&.strftime("%b %d, %Y") %></td>
          <td style="padding: 0.75rem;">
            <span style="background: #e8f4fd; color: #1a5276; padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.8rem;">
              <%= app.status.humanize %>
            </span>
          </td>
          <td style="padding: 0.75rem;">
            <%= link_to "View", application_path(app), style: "color: #3498db; margin-right: 0.5rem;" %>
            <% if policy(app).destroy? %>
              <%= button_to "Delete", application_path(app), method: :delete,
                  style: "background: none; border: none; color: #e74c3c; cursor: pointer; padding: 0;",
                  data: { turbo_confirm: "Are you sure?" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p style="color: #666;">No applications found.</p>
<% end %>