<%= form_with model: @company, style: "max-width: 600px;" do |f| %>
  <% if @company.errors.any? %>
    <div style="background: #f8d7da; color: #721c24; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem;">
      <% @company.errors.full_messages.each do |msg| %>
        <p style="margin: 0;"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div style="margin-bottom: 1rem;">
    <%= f.label :name, style: "display: block; font-weight: bold; margin-bottom: 0.25rem;" %>
    <%= f.text_field :name, style: "width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;" %>
  </div>

  <div style="margin-bottom: 1rem;">
    <%= f.label :industry, style: "display: block; font-weight: bold; margin-bottom: 0.25rem;" %>
    <%= f.text_field :industry, style: "width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;" %>
  </div>

  <div style="margin-bottom: 1rem;">
    <%= f.label :website, style: "display: block; font-weight: bold; margin-bottom: 0.25rem;" %>
    <%= f.url_field :website, placeholder: "https://...", style: "width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;" %>
  </div>

  <div style="margin-bottom: 1.5rem;">
    <%= f.label :description, style: "display: block; font-weight: bold; margin-bottom: 0.25rem;" %>
    <%= f.text_area :description, rows: 4, style: "width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;" %>
  </div>

  <%= f.submit @company.new_record? ? "Create Company" : "Update Company",
      style: "background: #2c3e50; color: white; padding: 0.6rem 1.5rem; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem;" %>
  <%= link_to "Cancel", companies_path, style: "margin-left: 1rem; color: #666;" %>
<% end %>